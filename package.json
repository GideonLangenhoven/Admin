{
  "name": "capekayak",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/predev-port-check.mjs; next dev --webpack -H 127.0.0.1",
    "dev:turbo": "next dev -H 127.0.0.1 -p 3000",
    "dev:clean": "lsof -ti:3000 | xargs kill -9 2>/dev/null || true && rm -rf .next && next dev --webpack -H 127.0.0.1 -p 3000",
    "build": "next build --webpack",
    "build:turbo": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "check:edge": "deno check --config supabase/functions/deno.json --node-modules-dir=none supabase/functions/web-chat/index.ts && deno check --config supabase/functions/deno.json --node-modules-dir=none supabase/functions/wa-webhook/index.ts && deno check --config supabase/functions/deno.json --node-modules-dir=none supabase/functions/send-otp/index.ts && deno check --config supabase/functions/deno.json --node-modules-dir=none supabase/functions/my-bookings-lookup/index.ts",
    "check-security-drift": "node scripts/check-security-drift.mjs",
    "test:e2e": "playwright test",
    "test:e2e:bots": "playwright test tests/e2e/bot-regressions.spec.ts",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.spec.ts",
    "test:e2e:happy": "playwright test tests/e2e/happy-path-booking.spec.ts",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@next/bundle-analyzer": "^16.2.4",
    "@phosphor-icons/react": "^2.1.10",
    "@sentry/nextjs": "^10.51.0",
    "@supabase/supabase-js": "^2.95.3",
    "date-fns": "^4.1.0",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.575.0",
    "next": "^16.2.2",
    "react": "^19.2.4",
    "react-day-picker": "^9.13.2",
    "react-dom": "^19.2.4",
    "react-virtuoso": "^4.18.6",
    "recharts": "^3.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.24",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.2",
    "pg": "^8.20.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5",
    "vitest": "^2.1.9"
  },
  "packageManager": "npm@10.9.4",
  "engines": {
    "node": ">=20"
  }
}
