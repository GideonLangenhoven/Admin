# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NEVER commit secrets
.env*
.env.local
.env.production
.env.staging

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# security — prevent accidental credential leaks
*.pem
*.key
*.cert
credentials.json
service-account.json
secrets/

# separate repos inside project
.activityhub-onboarding-staging/
/booking/

# backups & temp files
.backups/
landing-pages/output/
node_modules_old/
.git_broken/
*.log
_tmp_*
supabase/.temp/

# editor & OS
.vscode/settings.json
.idea/
Thumbs.db

# Sentry
.sentryclirc

# Claude and test artifacts
.claude-flow/
.claude/
playwright-report/
test-results/
auto-research/
my-video/
video/
video1/
